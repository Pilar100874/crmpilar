<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pairing_gradient">

    <!-- Decorative brand strip on the left -->
    <LinearLayout
        android:id="@+id/brandPane"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        app:layout_constraintWidth_percent="0.38"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/pilar_logo"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilar"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV Signage"
            android:textColor="#93C5FD"
            android:textSize="18sp"
            android:letterSpacing="0.30"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="#F59E0B" />
    </LinearLayout>

    <!-- Card with pairing form -->
    <FrameLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="48dp"
        app:layout_constraintStart_toEndOf="@id/brandPane"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="36dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pair_title"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pair_sub"
                android:textColor="#94A3B8"
                android:textSize="15sp"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/btnScanQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pair_scan_qr"
                android:textSize="18sp"
                android:paddingVertical="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_success"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1F2A44" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ou digite manualmente"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:letterSpacing="0.15" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1F2A44" />
            </LinearLayout>

            <EditText
                android:id="@+id/inputCodigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pair_code_hint"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:padding="16dp"
                android:background="@drawable/bg_input"
                android:inputType="textCapCharacters"
                android:maxLength="8"
                android:layout_marginTop="16dp"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/inputToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pair_token_hint"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_input"
                android:inputType="text"
                android:layout_marginTop="12dp"
                android:importantForAutofill="no" />

            <Button
                android:id="@+id/btnPair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pair_button"
                android:textSize="18sp"
                android:paddingVertical="16dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_btn_primary"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F97316"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:gravity="center" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
