<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F1A"
    android:padding="48dp">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pair_title"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pair_sub"
        android:textColor="#A6B1C2"
        android:textSize="18sp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitle" />

    <Button
        android:id="@+id/btnScanQr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pair_scan_qr"
        android:textSize="20sp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="14dp"
        android:layout_marginTop="28dp"
        android:backgroundTint="#22C55E"
        android:textColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtSub" />

    <TextView
        android:id="@+id/txtOr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="— ou digite manualmente —"
        android:textColor="#7A8599"
        android:textSize="14sp"
        android:layout_marginTop="18dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnScanQr" />

    <EditText
        android:id="@+id/inputCodigo"
        android:layout_width="480dp"
        android:layout_height="wrap_content"
        android:hint="@string/pair_code_hint"
        android:textColorHint="#7A8599"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:padding="16dp"
        android:background="#1A2033"
        android:inputType="textCapCharacters"
        android:maxLength="8"
        android:layout_marginTop="14dp"
        android:importantForAutofill="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtOr" />

    <EditText
        android:id="@+id/inputToken"
        android:layout_width="640dp"
        android:layout_height="wrap_content"
        android:hint="@string/pair_token_hint"
        android:textColorHint="#7A8599"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="16dp"
        android:background="#1A2033"
        android:inputType="text"
        android:layout_marginTop="14dp"
        android:importantForAutofill="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputCodigo" />

    <Button
        android:id="@+id/btnPair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pair_button"
        android:textSize="20sp"
        android:paddingHorizontal="40dp"
        android:paddingVertical="12dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#3B82F6"
        android:textColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputToken" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#F97316"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnPair" />

</androidx.constraintlayout.widget.ConstraintLayout>
