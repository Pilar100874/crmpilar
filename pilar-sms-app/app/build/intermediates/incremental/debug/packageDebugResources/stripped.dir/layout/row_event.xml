<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <View
        android:id="@+id/rowDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/dot_success"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/rowPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+55 11 99999-9999"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/rowSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Enviado às 14:32"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>

    <TextView
        android:id="@+id/rowPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="OK"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="@color/success"
        android:background="@drawable/pill_success"/>
</LinearLayout>
