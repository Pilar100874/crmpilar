{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ioxugupvxlcdweldocmq.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "pilar-mcp",
      "version": "0.3.0",
      "title": "Pilar CRM MCP"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna dados do usuário Pilar autenticado (id, nome, e-mail, estabelecimento).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_empresas",
        "title": "Listar empresas (com filtros)",
        "description": "Lista empresas do CRM Pilar visíveis para o usuário autenticado. Permite filtrar por UF (estado), cidade, segmento (por id ou nome), e exigir presença de e-mail e/ou WhatsApp. Retorna nome, nome fantasia, CNPJ, e-mail(s), telefone, WhatsApp(s), cidade, UF e segmento — pronto para o assistente montar tabela.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto livre em nome, nome fantasia ou CNPJ."
            },
            "uf": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2,
              "description": "UF (2 letras), ex: SP, RJ, MG."
            },
            "cidade": {
              "type": "string",
              "description": "Cidade (busca parcial, case-insensitive)."
            },
            "segmento_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID do segmento (use list_segmentos para descobrir)."
            },
            "segmento_nome": {
              "type": "string",
              "description": "Nome do segmento (busca parcial). Alternativa a segmento_id."
            },
            "com_email": {
              "type": "boolean",
              "description": "Se true, retorna somente empresas com e-mail cadastrado."
            },
            "com_whatsapp": {
              "type": "boolean",
              "description": "Se true, retorna somente empresas com WhatsApp/telefone cadastrado."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500,
              "description": "Máximo de registros (padrão 50, máx 500)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_produtos",
        "title": "Listar produtos",
        "description": "Lista produtos do estabelecimento do usuário autenticado. Suporta busca por nome/código.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto a buscar em nome, código ou marca."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Número máximo (padrão 25, máx 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_segmentos",
        "title": "Listar segmentos",
        "description": "Lista os segmentos de empresa cadastrados no Pilar. Use para descobrir o id/nome de um segmento antes de filtrar em list_empresas.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Filtro parcial pelo nome do segmento."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200,
              "description": "Máximo (padrão 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "listar_tabelas_disponiveis",
        "title": "Listar tabelas liberadas para consulta",
        "description": "Retorna a lista de tabelas do Pilar que estão liberadas para consulta via MCP (configuradas na tela 'Disponibilizar dados para Cloud Code / Cursor / ChatGPT'). Use antes de 'consultar_tabela'.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "consultar_tabela",
        "title": "Consultar uma tabela liberada",
        "description": "Consulta uma tabela do sistema Pilar que foi previamente liberada pelo administrador na tela 'Disponibilizar dados para Cloud Code / Cursor / ChatGPT'. Use 'listar_tabelas_disponiveis' primeiro para saber quais tabelas estão disponíveis. Retorna os registros (respeitando RLS do usuário autenticado).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "tabela": {
              "type": "string",
              "description": "Nome exato da tabela (ex.: empresas, produtos, orcamentos). Precisa estar na lista de tabelas liberadas."
            },
            "colunas": {
              "type": "string",
              "description": "Colunas separadas por vírgula (padrão: *)."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500,
              "description": "Máximo de registros (padrão 50, máx 500)."
            },
            "order_by": {
              "type": "string",
              "description": "Coluna para ordenar."
            },
            "ordem": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "description": "Direção da ordenação (padrão asc)."
            }
          },
          "required": [
            "tabela"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "salvar_empresa_prospectada",
        "title": "Salvar empresa prospectada",
        "description": "Insere UMA empresa pesquisada na web na tela 'Prospecção Empresas' do Listas do Pilar CRM. Use para trazer leads pesquisados de fontes externas (site, Google, LinkedIn, etc.) para dentro do Pilar. Depois o usuário revisa e importa para o cadastro definitivo de Empresas. Para vários leads de uma vez, use `salvar_empresas_prospectadas`.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "nome": {
              "type": "string",
              "minLength": 1,
              "description": "Razão social ou nome da empresa (obrigatório)."
            },
            "nome_fantasia": {
              "type": "string"
            },
            "cnpj": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "telefone": {
              "type": "string",
              "description": "Telefone geral."
            },
            "whatsapp": {
              "type": "string",
              "description": "Número WhatsApp com DDD."
            },
            "site": {
              "type": "string"
            },
            "endereco": {
              "type": "string"
            },
            "bairro": {
              "type": "string"
            },
            "cidade": {
              "type": "string"
            },
            "estado": {
              "type": "string",
              "description": "UF (2 letras)."
            },
            "cep": {
              "type": "string"
            },
            "cnae_principal": {
              "type": "string"
            },
            "cnae_descricao": {
              "type": "string"
            },
            "segmento_nome": {
              "type": "string",
              "description": "Segmento (texto livre)."
            },
            "descricao": {
              "type": "string",
              "description": "Descrição / resumo da empresa."
            },
            "redes_sociais": {
              "type": "object",
              "properties": {
                "instagram": {
                  "type": "string"
                },
                "facebook": {
                  "type": "string"
                },
                "linkedin": {
                  "type": "string"
                },
                "youtube": {
                  "type": "string"
                },
                "tiktok": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "fontes": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "description": "URLs das fontes usadas na pesquisa."
            },
            "contato_nome": {
              "type": "string",
              "description": "Nome do decisor/contato principal."
            },
            "contato_cargo": {
              "type": "string",
              "description": "Cargo do contato (ex.: Sócio, Diretor Comercial)."
            },
            "contato_email": {
              "type": "string"
            },
            "contato_telefone": {
              "type": "string"
            },
            "porte": {
              "type": "string",
              "description": "MEI, ME, EPP, Médio, Grande."
            },
            "faturamento_estimado": {
              "type": "string",
              "description": "Faixa de faturamento anual estimado."
            },
            "funcionarios_estimado": {
              "type": "string",
              "description": "Faixa de nº de funcionários (ex.: 1-9, 10-49)."
            },
            "data_fundacao": {
              "type": "string",
              "description": "Data de fundação em YYYY-MM-DD."
            },
            "situacao_cadastral": {
              "type": "string",
              "description": "ATIVA, BAIXADA, SUSPENSA, INAPTA."
            },
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Score de qualificação 0-100."
            },
            "score_motivo": {
              "type": "string",
              "description": "Justificativa curta do score."
            },
            "produtos_interesse": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Produtos/serviços de interesse."
            },
            "prioridade": {
              "type": "string",
              "description": "alta, media, baixa."
            },
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "observacoes_internas": {
              "type": "string"
            },
            "origem": {
              "type": "string",
              "description": "Origem do lead. Use 'vendedor' para representantes comerciais, 'claude-code' (default) para empresas."
            },
            "extras": {
              "type": "object",
              "additionalProperties": {},
              "description": "Qualquer dado extra relevante em JSON."
            }
          },
          "required": [
            "nome"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
