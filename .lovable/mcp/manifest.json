{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ioxugupvxlcdweldocmq.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "pilar-mcp",
      "version": "0.2.0",
      "title": "Pilar CRM MCP"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna dados do usuário Pilar autenticado (id, nome, e-mail, estabelecimento).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_empresas",
        "title": "Listar empresas (com filtros)",
        "description": "Lista empresas do CRM Pilar visíveis para o usuário autenticado. Permite filtrar por UF (estado), cidade, segmento (por id ou nome), e exigir presença de e-mail e/ou WhatsApp. Retorna nome, nome fantasia, CNPJ, e-mail(s), telefone, WhatsApp(s), cidade, UF e segmento — pronto para o assistente montar tabela.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto livre em nome, nome fantasia ou CNPJ."
            },
            "uf": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2,
              "description": "UF (2 letras), ex: SP, RJ, MG."
            },
            "cidade": {
              "type": "string",
              "description": "Cidade (busca parcial, case-insensitive)."
            },
            "segmento_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID do segmento (use list_segmentos para descobrir)."
            },
            "segmento_nome": {
              "type": "string",
              "description": "Nome do segmento (busca parcial). Alternativa a segmento_id."
            },
            "com_email": {
              "type": "boolean",
              "description": "Se true, retorna somente empresas com e-mail cadastrado."
            },
            "com_whatsapp": {
              "type": "boolean",
              "description": "Se true, retorna somente empresas com WhatsApp/telefone cadastrado."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500,
              "description": "Máximo de registros (padrão 50, máx 500)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_produtos",
        "title": "Listar produtos",
        "description": "Lista produtos do estabelecimento do usuário autenticado. Suporta busca por nome/código.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto a buscar em nome, código ou marca."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Número máximo (padrão 25, máx 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_segmentos",
        "title": "Listar segmentos",
        "description": "Lista os segmentos de empresa cadastrados no Pilar. Use para descobrir o id/nome de um segmento antes de filtrar em list_empresas.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Filtro parcial pelo nome do segmento."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200,
              "description": "Máximo (padrão 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "add_prospeccao_empresa",
        "title": "Adicionar empresa à Prospecção",
        "description": "Insere uma empresa pesquisada na web na tela 'Prospecção Empresas' do Listas. Use para trazer leads pesquisados de fontes externas (site, Google, LinkedIn, etc.) para dentro do CRM Pilar. Depois o usuário revisa e importa para o cadastro definitivo de Empresas. Use `add_prospeccao_empresas_bulk` para vários de uma vez.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "nome": {
              "type": "string",
              "minLength": 1,
              "description": "Razão social ou nome da empresa (obrigatório)."
            },
            "nome_fantasia": {
              "type": "string"
            },
            "cnpj": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "telefone": {
              "type": "string",
              "description": "Telefone geral."
            },
            "whatsapp": {
              "type": "string",
              "description": "Número WhatsApp com DDD."
            },
            "site": {
              "type": "string"
            },
            "endereco": {
              "type": "string"
            },
            "bairro": {
              "type": "string"
            },
            "cidade": {
              "type": "string"
            },
            "estado": {
              "type": "string",
              "description": "UF (2 letras)."
            },
            "cep": {
              "type": "string"
            },
            "cnae_principal": {
              "type": "string"
            },
            "cnae_descricao": {
              "type": "string"
            },
            "segmento_nome": {
              "type": "string",
              "description": "Segmento (texto livre)."
            },
            "descricao": {
              "type": "string",
              "description": "Descrição / resumo da empresa."
            },
            "redes_sociais": {
              "type": "object",
              "properties": {
                "instagram": {
                  "type": "string"
                },
                "facebook": {
                  "type": "string"
                },
                "linkedin": {
                  "type": "string"
                },
                "youtube": {
                  "type": "string"
                },
                "tiktok": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "fontes": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "description": "URLs das fontes usadas na pesquisa."
            },
            "extras": {
              "type": "object",
              "additionalProperties": {},
              "description": "Qualquer dado extra relevante em JSON."
            }
          },
          "required": [
            "nome"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "add_prospeccao_empresas_bulk",
        "title": "Adicionar várias empresas à Prospecção",
        "description": "Insere um lote de empresas pesquisadas em 'Prospecção Empresas'. Use quando o assistente já compilou uma lista (ex.: 20 indústrias em SP). Máximo 100 por chamada.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "empresas": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string",
                    "minLength": 1
                  },
                  "nome_fantasia": {
                    "type": "string"
                  },
                  "cnpj": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "telefone": {
                    "type": "string"
                  },
                  "whatsapp": {
                    "type": "string"
                  },
                  "site": {
                    "type": "string"
                  },
                  "endereco": {
                    "type": "string"
                  },
                  "bairro": {
                    "type": "string"
                  },
                  "cidade": {
                    "type": "string"
                  },
                  "estado": {
                    "type": "string"
                  },
                  "cep": {
                    "type": "string"
                  },
                  "cnae_principal": {
                    "type": "string"
                  },
                  "cnae_descricao": {
                    "type": "string"
                  },
                  "segmento_nome": {
                    "type": "string"
                  },
                  "descricao": {
                    "type": "string"
                  },
                  "redes_sociais": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "fontes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "extras": {
                    "type": "object",
                    "additionalProperties": {}
                  }
                },
                "required": [
                  "nome"
                ],
                "additionalProperties": false
              },
              "minItems": 1,
              "maxItems": 100,
              "description": "Lista de empresas a inserir."
            }
          },
          "required": [
            "empresas"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
