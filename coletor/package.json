{
  "name": "ponto-coletor",
  "version": "1.4.2",
  "description": "Coletor de batidas de relógios de ponto - CRM Pilar (pré-configurado)",
  "main": "main.js",
  "author": "Pilar",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "dist:msi": "electron-builder --win msi --x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "ffmpeg-static": "^5.3.0",
    "werift": "^0.23.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "br.com.pilar.coletor",
    "productName": "ColetorPilar",
    "artifactName": "ColetorPilar-Setup.msi",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist-installer${/*}"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "msi",
          "arch": ["x64"]
        }
      ]
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Coletor Pilar"
    }
  }
}
