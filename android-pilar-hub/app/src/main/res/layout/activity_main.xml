<?xml version="1.0" encoding="utf-8"?>
<!-- Layout espelhando o Coletor Desktop:
     header com badge de versão, card do dispositivo, cards de módulos, botões estilo desktop. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header (equivalente ao <h1> "🕒 Coletor Desktop v—") -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📱 Pilar Hub"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="v1.2.0"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gateway SMS · consumo mínimo de bateria"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="14dp" />

        <!-- Card: Dispositivo / token -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 Dispositivo"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Token do dispositivo"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/tokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hint="Cole o token gerado no CRM"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:inputType="text" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_primary"
                android:text="Salvar e iniciar"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <!-- Módulos Ponto e Câmera são responsabilidade do Coletor Desktop (MSI). -->


        <!-- Card: SMS -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉️ Gateway SMS"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fila consultada a cada 5s · consumo mínimo de bateria."
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Status geral -->
        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginTop="6dp" />
    </LinearLayout>
</ScrollView>
